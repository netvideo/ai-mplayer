{
  "$schema": "http://schema.tauri.app/config/2.0",
  "identifier": "default",
  "description": "Default capabilities for ai-mplayer with restricted file system access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-start-dragging",
    "core:app:default",
    "core:resources:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "libmpv:default"
  ]
}
